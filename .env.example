# Copy this file to .env and fill in real values for local development.
# In production (Render), set these in the host's secret manager instead.
# .env is git ignored; .env.example (this file) is committed as the template.

# --- Anthropic / Claude vision (required for extraction, Task Group 3) ---
ANTHROPIC_API_KEY=
# Optional: pin the vision model id (confirmed via the claude-api reference at build time).
CLAUDE_MODEL=

# --- App config (optional) ---
# Reject uploads larger than this many megabytes before processing.
MAX_UPLOAD_MB=10
# dev or prod; controls log verbosity.
APP_ENV=dev
